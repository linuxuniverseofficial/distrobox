#!/bin/bash

set -e  # Para em caso de erro
echo "=== Criando e configurando distrobox Ubuntu 24.04 com ROCm ==="

# Etapa 1: Criar distrobox
echo "[1/3] Criando distrobox..."
distrobox create --name ubuntu2404 -i ubuntu:24.04

# Etapa 2: Setup inicial dentro do distrobox
echo "[2/3] Configurando ambiente base..."
distrobox enter ubuntu2404 -- bash << 'EOF'
set -e

sudo apt update
sudo apt install -y build-essential libnuma-dev wget gnupg2

sudo usermod -a -G video $LOGNAME
echo 'ADD_EXTRA_GROUPS=1' | sudo tee -a /etc/adduser.conf
echo 'EXTRA_GROUPS=video' | sudo tee -a /etc/adduser.conf
echo 'EXTRA_GROUPS=render' | sudo tee -a /etc/adduser.conf

wget https://repo.radeon.com/amdgpu-install/latest/ubuntu/noble/amdgpu-install_7.1.1.70101-1_all.deb; sleep 1
sudo apt install ./amdgpu-install_7.1.1.70101-1_all.deb || true

sudo apt update; sudo amdgpu-install -y --usecase=rocm,hip --no-dkms
echo 'export PATH=$PATH:/opt/rocm/bin:/opt/rocm/rocprofiler/bin:/opt/rocm/opencl/bin' >> ~/.bashrc

EOF

# Etapa 3: Reiniciar distrobox e instalar libs finais
echo "[3/3] Reiniciando distrobox e instalando bibliotecas ROCm..."
podman stop ubuntu2404
sleep 2; distrobox enter ubuntu2404 -- bash << 'EOF'
set -e

source ~/.bashrc
rocminfo; sleep 1
sudo apt install -y rocm-libs hipcub miopen-hip rccl

echo ""
echo "=== Configuração concluída! ==="
EOF

echo ""
echo "✓ Setup completo!"
